# --- Existing NurseSquare integrations ---
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (outbound email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
CRON_SECRET=

# Checkr (optional; routes fall through gracefully when blank)
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=
CHECKR_PACKAGE_SLUG=

# Nursys / NCSBN e-Notify
NURSYS_BASE_URL=
NURSYS_API_USERNAME=
NURSYS_API_PASSWORD=

# --- Pay-Package Ledger (Module 1) ---
# Anthropic (Sonnet for extraction, Haiku for free-text diff)
ANTHROPIC_API_KEY=

# Postmark inbound email (forwarding_email -> POST /api/ledger/webhooks/postmark)
# Leave blank to disable; the route will return 503 until populated.
POSTMARK_INBOUND_SECRET=

# Twilio inbound SMS (forwarding_sms_number -> POST /api/ledger/webhooks/twilio)
# Leave blank to disable; the route will return 503 until populated.
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
